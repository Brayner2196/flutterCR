{
    "java.configuration.updateBuildConfiguration": "interactive",
    "claude": {
        "agents": {
            "brainstorming-flutterCR": {
                "enabled": true,
                "trigger": "manual",
                "keywords": [
                    "feature nueva",
                    "nuevo feature",
                    "componente",
                    "widget",
                    "refactoring",
                    "architecture",
                    "diseño",
                    "brainstorm",
                    "mejora",
                    "optimización"
                ],
                "autoActivate": {
                    "enabled": true,
                    "triggers": [
                        "user asks about new feature or functionality",
                        "user mentions refactoring or code improvement",
                        "user discusses architecture or design",
                        "user talks about creating a component or widget",
                        "user mentions optimization or performance"
                    ]
                },
                "instructions": ".instructions.md",
                "contextFiles": [
                    "CLAUDE.md",
                    ".agent.md",
                    "brainstorming-templates.md"
                ]
            }
        }
    },
    "workbench.colorCustomizations": {
        "activityBar.activeBackground": "#ab307e",
        "activityBar.background": "#ab307e",
        "activityBar.foreground": "#e7e7e7",
        "activityBar.inactiveForeground": "#e7e7e799",
        "activityBarBadge.background": "#25320e",
        "activityBarBadge.foreground": "#e7e7e7",
        "commandCenter.border": "#e7e7e799",
        "editorGroup.border": "#ab307e",
        "panel.border": "#ab307e",
        "sash.hoverBorder": "#ab307e",
        "sideBar.border": "#ab307e",
        "statusBar.background": "#832561",
        "statusBar.border": "#832561",
        "statusBar.debuggingBackground": "#258347",
        "statusBar.debuggingBorder": "#258347",
        "statusBar.debuggingForeground": "#e7e7e7",
        "statusBar.foreground": "#e7e7e7",
        "statusBarItem.hoverBackground": "#ab307e",
        "statusBarItem.remoteBackground": "#832561",
        "statusBarItem.remoteForeground": "#e7e7e7",
        "titleBar.activeBackground": "#832561",
        "titleBar.activeForeground": "#e7e7e7",
        "titleBar.border": "#832561",
        "titleBar.inactiveBackground": "#83256199",
        "titleBar.inactiveForeground": "#e7e7e799"
    },
    "peacock.color": "#832561"
}